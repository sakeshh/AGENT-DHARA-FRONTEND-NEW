# Frontend env example (DO NOT COMMIT real secrets)

# Frontend → Backend bridge (FastAPI LangGraph/MCP server)
BACKEND_BASE_URL=http://127.0.0.1:8000
BACKEND_AUTH_TOKEN=change-me

# Optional: Azure OpenAI (used by backend NL->SQL and/or frontend direct mode)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT_NAME=
AZURE_OPENAI_API_VERSION=2024-02-01-preview

# Azure AI Foundry AGENT (not the deployed model) – chat uses threads + runs.
# Copy to .env.local and fill in. See docs/AZURE_AGENT_SETUP.md

# Project base URL (from Project Overview or Settings)
AZURE_AGENT_ENDPOINT=

# API key (Project Settings → Keys and endpoints – same project as endpoint)
AZURE_AGENT_API_KEY=your-api-key-here

# Your agent's ID (from the agent page URL or Playground → View code). Required to invoke the agent.
AZURE_AGENT_ID=your-agent-id-here

# Optional: if you get 401 "invalid subscription key", try: api-key or ocp-apim (default is Bearer)
# AZURE_AGENT_AUTH_HEADER=api-key
